#!/bin/bash
# Mock mount - 模拟挂载操作

# 模拟已挂载的设备（不能重复挂载）
MOCK_MOUNTS_FILE="${TEST_MOCK_DIR:-/Users/jinbingjie/Desktop/加密盘挂在程序/test_mock}/.mock_mounts"

# 初始化挂载记录文件
touch "$MOCK_MOUNTS_FILE"

mount_point=""
device=""

# 解析参数，只处理 -o, -t 和以 / 开头的路径参数
for arg in "$@"; do
    case "$arg" in
        -o|--*)
            # 跳过选项及其值
            continue
            ;;
        -t)
            continue
            ;;
        /*)
            if [[ -z "$device" ]]; then
                device="$arg"
            else
                mount_point="$arg"
            fi
            ;;
    esac
done

# 如果没有传递设备和挂载点，显示帮助
if [[ -z "$device" || -z "$mount_point" ]]; then
    echo "Usage: mount device mountpoint" >&2
    exit 1
fi

# 提取设备名称（去除路径中的 /dev/ 前缀或完整路径）
device_name="${device##*/}"

# 检查是否已挂载（使用设备名称匹配）
if grep -q " ${device_name} " "$MOCK_MOUNTS_FILE" 2>/dev/null; then
    echo "mount: $device_name already mounted" >&2
    exit 1
fi

# 模拟挂载成功 - 记录挂载信息
echo "${device_name} ${mount_point}" >> "$MOCK_MOUNTS_FILE"
exit 0
